generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "sqlite"
}

model Product {
  id          Int            @id @default(autoincrement())
  name        String
  description String
  price       Float
  stock       Int
  categoryId  Int
  category    Category       @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  products    Product[]
}

model ProductImage {
  id        String  @id @default(uuid())
  url       String
  isMain    Boolean @default(false)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
}

model User {
  id String @id @default(uuid())
  fullName String
  email String @unique
  password String
  rol String @default("CLIENT")
}